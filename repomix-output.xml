package com.example.notificationservice.domain.useCase;

import com.example.notificationservice.domain.model.Destinatario;
import com.example.notificationservice.domain.model.gateway.DestinatarioGateway;
import java.util.List;
import java.util.Optional;

public class DestinatarioUseCase {

    private final DestinatarioGateway destinatarioGateway;

    public DestinatarioUseCase(DestinatarioGateway destinatarioGateway) {
        this.destinatarioGateway = destinatarioGateway;
    }

    public Destinatario save(Destinatario entity) {
        try {
            return destinatarioGateway.save(entity);
        } catch (Exception e) {
            throw new RuntimeException("Error al guardar Destinatario: " + e.getMessage());
        }
    }

    public Optional<Destinatario> findById(String id) {
        try {
            return destinatarioGateway.findById(id);
        } catch (Exception e) {
            throw new RuntimeException("Error al buscar Destinatario: " + e.getMessage());
        }
    }

    public List<Destinatario> findAll() {
        try {
            return destinatarioGateway.findAll();
        } catch (Exception e) {
            throw new RuntimeException("Error al listar Destinatarios: " + e.getMessage());
        }
    }

    public void deleteById(String id) {
        try {
            destinatarioGateway.deleteById(id);
        } catch (Exception e) {
            throw new RuntimeException("Error al eliminar Destinatario: " + e.getMessage());
        }
    }
}
</file>

