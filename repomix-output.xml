package com.example.productservice.infrastructure.entity_points;

import lombok.RequiredArgsConstructor;
import com.example.productservice.domain.model.Producto;
import com.example.productservice.domain.useCase.ProductoUseCase;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import java.util.List;
import java.util.stream.Collectors;

@RestController
@RequestMapping("/api/productos")
@RequiredArgsConstructor
public class ProductoController {

    private final ProductoUseCase productoUseCase;

    @GetMapping
    public ResponseEntity<List<ProductoResponse>> findAll() {
        List<ProductoResponse> lista = productoUseCase.findAll().stream()
                .map(this::toResponse)
                .collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @GetMapping("/{id}")
    public ResponseEntity<ProductoResponse> findById(@PathVariable String id) {
        return productoUseCase.findById(id)
                .map(p -> ResponseEntity.ok(toResponse(p)))
                .orElse(ResponseEntity.notFound().build());
    }

    @GetMapping("/sku/{sku}")
    public ResponseEntity<ProductoResponse> findBySku(@PathVariable String sku) {
        return productoUseCase.findBySku(sku)
                .map(p -> ResponseEntity.ok(toResponse(p)))
                .orElse(ResponseEntity.notFound().build());
    }

    @GetMapping("/categoria/{categoria}")
    public ResponseEntity<List<ProductoResponse>> findByCategoria(@PathVariable String categoria) {
        List<ProductoResponse> lista = productoUseCase.findByCategoria(categoria).stream()
                .map(this::toResponse)
                .collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @PostMapping
    public ResponseEntity<ProductoResponse> create(@RequestBody ProductoRequest request) {
        Producto saved = productoUseCase.save(toDomain(request));
        return ResponseEntity.ok(toResponse(saved));
    }

    @PutMapping("/{id}")
    public ResponseEntity<ProductoResponse> update(@PathVariable String id,
                                                    @RequestBody ProductoRequest request) {
        Producto domain = toDomain(request);
        domain.setId(id);
        return ResponseEntity.ok(toResponse(productoUseCase.save(domain)));
    }

    @DeleteMapping("/{id}")
    public ResponseEntity<Void> delete(@PathVariable String id) {
        productoUseCase.deleteById(id);
        return ResponseEntity.noContent().build();
    }

    private Producto toDomain(ProductoRequest req) {
        return Producto.builder()
                .nombre(req.getNombre())
                .descripcion(req.getDescripcion())
                .categoria(req.getCategoria())
                .sku(req.getSku())
                .precio(req.getPrecio())
                .build();
    }

    private ProductoResponse toResponse(Producto p) {
        return ProductoResponse.builder()
                .id(p.getId())
                .nombre(p.getNombre())
                .descripcion(p.getDescripcion())
                .categoria(p.getCategoria())
                .sku(p.getSku())
                .precio(p.getPrecio())
                .build();
    }
}
