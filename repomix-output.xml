package com.example.notificationservice.infrastructure.entry_points;

import lombok.RequiredArgsConstructor;
import com.example.notificationservice.domain.model.Notificacion;
import com.example.notificationservice.domain.useCase.NotificacionUseCase;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.List;
import java.util.stream.Collectors;

@RestController
@RequestMapping("/api/notificaciones")
@RequiredArgsConstructor
public class NotificationController {

    private final NotificacionUseCase notificacionUseCase;

    @GetMapping
    public ResponseEntity<List<NotificacionResponse>> findAll() {
        List<NotificacionResponse> lista = notificacionUseCase.findAll().stream()
                .map(this::toResponse).collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @GetMapping("/{id}")
    public ResponseEntity<NotificacionResponse> findById(@PathVariable String id) {
        return notificacionUseCase.findById(id)
                .map(n -> ResponseEntity.ok(toResponse(n)))
                .orElse(ResponseEntity.notFound().build());
    }

    @PostMapping
    public ResponseEntity<NotificacionResponse> create(@RequestBody NotificacionRequest request) {
        Notificacion saved = notificacionUseCase.save(toDomain(request));
        return ResponseEntity.ok(toResponse(saved));
    }

    @DeleteMapping("/{id}")
    public ResponseEntity<Void> delete(@PathVariable String id) {
        notificacionUseCase.deleteById(id);
        return ResponseEntity.noContent().build();
    }

    private Notificacion toDomain(NotificacionRequest req) {
        return Notificacion.builder()
                .destinatarioId(req.getDestinatarioId())
                .mensaje(req.getMensaje())
                .tipo(req.getTipo())
                .fechaEnvio(LocalDateTime.now())
                .enviada(false)
                .build();
    }

    private NotificacionResponse toResponse(Notificacion n) {
        return NotificacionResponse.builder()
                .id(n.getId())
                .destinatarioId(n.getDestinatarioId())
                .mensaje(n.getMensaje())
                .tipo(n.getTipo())
                .fechaEnvio(n.getFechaEnvio())
                .enviada(n.getEnviada())
                .build();
    }
}
