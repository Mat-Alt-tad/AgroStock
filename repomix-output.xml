    @GetMapping
    public ResponseEntity<List<OrdenCompraResponse>> findAll() {
        List<OrdenCompraResponse> lista = ordenCompraUseCase.findAll().stream()
                .map(this::toResponse).collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @GetMapping("/{id}")
    public ResponseEntity<OrdenCompraResponse> findById(@PathVariable String id) {
        return ordenCompraUseCase.findById(id)
                .map(o -> ResponseEntity.ok(toResponse(o)))
                .orElse(ResponseEntity.notFound().build());
    }

    @GetMapping("/usuario/{usuarioId}")
    public ResponseEntity<List<OrdenCompraResponse>> findByUsuarioId(@PathVariable String usuarioId) {
        List<OrdenCompraResponse> lista = ordenCompraUseCase.findByUsuarioId(usuarioId).stream()
                .map(this::toResponse).collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @GetMapping("/estado/{estado}")
    public ResponseEntity<List<OrdenCompraResponse>> findByEstado(@PathVariable String estado) {
        List<OrdenCompraResponse> lista = ordenCompraUseCase.findByEstado(estado).stream()
                .map(this::toResponse).collect(Collectors.toList());
        return ResponseEntity.ok(lista);
    }

    @PostMapping
    public ResponseEntity<OrdenCompraResponse> create(@RequestBody OrdenCompraRequest request) {
        OrdenCompra saved = ordenCompraUseCase.save(toDomain(request));
        return ResponseEntity.ok(toResponse(saved));
    }

    @PutMapping("/{id}")
    public ResponseEntity<OrdenCompraResponse> update(@PathVariable String id,
                                                       @RequestBody OrdenCompraRequest request) {
        OrdenCompra domain = toDomain(request);
        domain.setId(id);
        return ResponseEntity.ok(toResponse(ordenCompraUseCase.save(domain)));
    }

    @DeleteMapping("/{id}")
    public ResponseEntity<Void> delete(@PathVariable String id) {
        ordenCompraUseCase.deleteById(id);
        return ResponseEntity.noContent().build();
    }

    private OrdenCompra toDomain(OrdenCompraRequest req) {
        return OrdenCompra.builder()
                .usuarioId(req.getUsuarioId())
                .estado(req.getEstado())
                .fecha(LocalDateTime.now())
                .total(req.getTotal())
                .build();
    }

    private OrdenCompraResponse toResponse(OrdenCompra o) {
        return OrdenCompraResponse.builder()
                .id(o.getId())
                .usuarioId(o.getUsuarioId())
                .estado(o.getEstado())
                .fecha(o.getFecha())
                .total(o.getTotal())
                .build();
