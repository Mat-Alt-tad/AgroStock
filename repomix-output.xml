    public ResponseEntity<RecepcionResponse> findById(@PathVariable String id) {
        return recepcionUseCase.findById(id)
                .map(r -> ResponseEntity.ok(toResponse(r)))
                .orElse(ResponseEntity.notFound().build());
    }

    @GetMapping("/orden/{ordenId}")
    public ResponseEntity<RecepcionResponse> findByOrdenId(@PathVariable String ordenId) {
        return recepcionUseCase.findByOrdenId(ordenId)
                .map(r -> ResponseEntity.ok(toResponse(r)))
                .orElse(ResponseEntity.notFound().build());
    }

    @PostMapping
    public ResponseEntity<RecepcionResponse> create(
            @RequestBody RecepcionRequest request,
            @RequestHeader("Authorization") String authHeader) {
        String token = authHeader.replace("Bearer ", "");
        Recepcion recepcion = Recepcion.builder()
                .ordenId(request.getOrdenId())
                .fechaRecepcion(LocalDateTime.now())
                .observaciones(request.getObservaciones())
                .build();
        Recepcion saved = recepcionUseCase.save(
                recepcion,
                request.getStockItemId(),
                request.getCantidadRecibida(),
                token
        );
        return ResponseEntity.ok(toResponse(saved));
    }

    @DeleteMapping("/{id}")
    public ResponseEntity<Void> delete(@PathVariable String id) {
        recepcionUseCase.deleteById(id);
        return ResponseEntity.noContent().build();
    }

    private RecepcionResponse toResponse(Recepcion r) {
        return RecepcionResponse.builder()
                .id(r.getId())
                .ordenId(r.getOrdenId())
                .fechaRecepcion(r.getFechaRecepcion())
                .observaciones(r.getObservaciones())
                .build();
    }
}
