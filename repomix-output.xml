package com.example.productservice.domain.useCase;

import com.example.productservice.domain.model.Categoria;
import com.example.productservice.domain.model.gateway.CategoriaGateway;
import java.util.List;
import java.util.Optional;

public class CategoriaUseCase {

    private final CategoriaGateway categoriaGateway;

    public CategoriaUseCase(CategoriaGateway categoriaGateway) {
        this.categoriaGateway = categoriaGateway;
    }

    public Categoria save(Categoria entity) {
        try {
            return categoriaGateway.save(entity);
        } catch (Exception e) {
            throw new RuntimeException("Error al guardar Categoria: " + e.getMessage());
        }
    }

    public Optional<Categoria> findById(String id) {
        try {
            return categoriaGateway.findById(id);
        } catch (Exception e) {
            throw new RuntimeException("Error al buscar Categoria: " + e.getMessage());
        }
    }

    public List<Categoria> findAll() {
        try {
            return categoriaGateway.findAll();
        } catch (Exception e) {
            throw new RuntimeException("Error al listar Categoria: " + e.getMessage());
        }
    }

    public void deleteById(String id) {
        try {
            categoriaGateway.deleteById(id);
        } catch (Exception e) {
            throw new RuntimeException("Error al eliminar Categoria: " + e.getMessage());
        }
    }
}
